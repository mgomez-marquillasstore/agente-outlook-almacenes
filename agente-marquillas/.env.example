# ════════════════════════════════════════════════════════════
# AGENTE MARQUILLAS S.A.S — Plantilla de variables de entorno
# ════════════════════════════════════════════════════════════
# INSTRUCCIONES:
#   1. Copia este archivo y renómbralo a ".env" (sin la extensión .example)
#   2. Reemplaza CADA valor de ejemplo con tu valor real
#   3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
# ════════════════════════════════════════════════════════════

# ── ANTHROPIC (CLAUDE AI) ──────────────────────────────────
# Clave de la API de Anthropic para acceder a Claude.
# Cómo obtenerla: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── MICROSOFT AZURE ────────────────────────────────────────
# Credenciales de la aplicación registrada en Azure Active Directory.
# El área de IT las genera en: https://portal.azure.com
# Ver sección "Cómo configurar Azure" en el README.md para instrucciones detalladas.

# Identificador único de la aplicación registrada en Azure
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Secreto de cliente generado en Azure (tratar como contraseña)
AZURE_CLIENT_SECRET=tu_secreto_de_azure_aqui_generado_en_portal

# Identificador del directorio (tenant) de la organización en Azure
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── CORREOS ────────────────────────────────────────────────
# Correo corporativo que el agente monitoreará (donde llegan las facturas con ZIP)
EMAIL_MONITOREAR=analista.programador@marquillasstore.com.co

# Correo al que se reenvía el PDF cuando la factura es APROBADA
EMAIL_DESTINO=analista.programador@marquillasstore.com.co

# ── CONFIGURACIÓN DEL AGENTE ───────────────────────────────
# Cada cuántos minutos el agente revisa si hay correos nuevos.
# Recomendado: 5 (no usar menos de 2 para no sobrecargar la API)
INTERVALO_MINUTOS=5
